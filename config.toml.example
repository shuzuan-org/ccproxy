[server]
host = "0.0.0.0"
port = 3000
# admin_password = ""  # Leave empty or omit to auto-generate on first start
# rate_limit = 60  # max requests per minute per IP for admin routes (default: 60)
base_url = "https://api.anthropic.com"
request_timeout = 300
max_concurrency = 5
# log_level = "info"    # debug, info, warn, error
# log_format = "text"   # text or json (json recommended for Docker/log aggregation)

# API keys — leave this section empty or omit entirely to auto-generate on first start
# [[api_keys]]
# key = "sk-ccproxy-987313a7b186d14afe045aa16335b032"
# name = "dev-team"
# enabled = true

# Instances are managed dynamically via the admin dashboard (Add Claude button).
# They are persisted in data/instances.json — no TOML config needed.
