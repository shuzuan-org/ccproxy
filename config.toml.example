[server]
host = "127.0.0.1"
port = 3000
# admin_password = ""  # Leave empty or omit to auto-generate on first start
# rate_limit = 60  # max requests per minute per IP for admin routes (default: 60)
base_url = "https://api.anthropic.com"
request_timeout = 600
max_concurrency = 5  # hard limit per account; effective value is dynamically adjusted by budget utilization
# log_level = "info"    # debug, info, warn, error
# auto_update = true          # enable background auto-upgrade (default: true)
# update_check_interval = "1h" # check interval, min 5m, max 24h (default: 1h)
# update_repo = "shuzuan-org/ccproxy" # GitHub owner/repo for update source
# update_api_url = ""  # GitHub Enterprise API URL (default: github.com)
# update_channel = "stable"   # Release channel: "stable" (default) or "beta" (includes pre-releases)

# API keys — each key represents a user who can manage their own Claude accounts.
# Leave this section empty or omit entirely to auto-generate 3 default users (alice/bob/charlie).
# The "password" field is the dashboard login password — leave empty to auto-generate.
# [[api_keys]]
# key = "sk-987313a7b186d14afe045aa16335b032987313a7b186d14afe045aa16335b032"
# name = "alice"
# password = ""  # Leave empty or omit to auto-generate
# enabled = true
# scheduling = ["*"]  # Optional — see "Scheduling scope" below.

# ----------------------------------------------------------------------------
# Scheduling scope (optional)
# ----------------------------------------------------------------------------
# By default every api_key dispatches requests to all enabled accounts
# (scheduling = ["*"]). To restrict which accounts a key can use, set
# "scheduling" on the api_key. Entries use the following syntax:
#
#   "self"         — accounts whose owner == this api_key name
#   "owner:<name>" — accounts whose owner matches the given name
#   "pool:<name>"  — expands to the members of the named [[pools]] block
#   "*"            — all enabled accounts (default; short-circuits other entries)
#   "unowned"      — accounts with no owner (rare; legacy/migrated only)
#
# [[pools]] is a naming convenience for reusing the same member list across
# multiple api_keys. It is not a runtime entity.
#
# Example: alice and bob share the "team-a" pool; charlie is isolated.
#
# [[pools]]
# name = "team-a"
# members = ["alice", "bob"]
#
# [[api_keys]]
# name = "alice"
# key = "sk-..."
# enabled = true
# scheduling = ["pool:team-a"]
#
# [[api_keys]]
# name = "bob"
# key = "sk-..."
# enabled = true
# scheduling = ["pool:team-a"]
#
# [[api_keys]]
# name = "charlie"
# key = "sk-..."
# enabled = true
# scheduling = ["self"]
#
# Changes to scheduling or pools require a restart (no hot reload).

# Accounts are managed dynamically per-user via the admin dashboard (Add Claude button).
# Each account has an "owner" field linking it to the api_key user who created it.
# By default all enabled accounts participate in global load balancing regardless
# of owner — set "scheduling" on an api_key to restrict its candidate pool.
# They are persisted in data/accounts.json — no TOML config needed.
#
# Dashboard login:
#   Admin:  username "admin", password = admin_password (read-only global view)
#   Users:  username = api_key name, password = api_key password (manage own accounts)
